PROJECT_NAME=capturador-datos-v2
ENV=dev
LOG_LEVEL=INFO
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/capturador
REDIS_URL=redis://redis:6379/0
OBJECT_STORAGE_ENDPOINT=minio:9000
OBJECT_STORAGE_ACCESS_KEY=minio
OBJECT_STORAGE_SECRET_KEY=minio123
FX_PROVIDER=official
FX_DEFAULT_USD_CLP_RATE=950
FX_TIMEOUT_SECONDS=5
FX_RETRY_COUNT=2
OCR_ENGINE=tesseract
COMPANY_RULES_PATH=docs/company_rules.example.json
OLLAMA_ENABLED=false
OLLAMA_API=http://localhost:11434/api
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT_SECONDS=30
OLLAMA_RETRY_COUNT=2
OLLAMA_BACKOFF_SECONDS=0.5
OLLAMA_REQUIRE_MODEL_AVAILABLE=true
AUTH_ENABLED=false
AUTH_SEED_USERS=true
ACCESS_TOKEN_MINUTES=30
REFRESH_TOKEN_DAYS=7
PASSWORD_SALT=capturador-v2
DEFAULT_SEED_PASSWORD=change_me_123
SECURITY_JWT_SECRET=change_me
SECURITY_JWT_ROTATED_AT=2026-05-16T00:00:00Z
SECURITY_JWT_MAX_AGE_DAYS=90
CORS_ALLOW_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type,X-Correlation-Id
UPLOAD_QUARANTINE_ENABLED=false
UPLOAD_QUARANTINE_DIR=/tmp/capturador_quarantine
OLLAMA_ALLOWED_HOSTS=localhost,127.0.0.1,kernelia-ollama,ollama
